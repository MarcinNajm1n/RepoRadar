OPENAI_DAILY_ANALYSIS_LIMIT=20
ENABLE_REDDIT_SOURCE=false
ENABLE_HN_SOURCE=false
ENABLE_PRODUCT_HUNT_SOURCE=false
ENABLE_X_SOURCE=false
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_REPORTS=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DISCORD_WEBHOOK_URL=
EXCLUDE_FORKS=true
REPORTS_DIR=reports
