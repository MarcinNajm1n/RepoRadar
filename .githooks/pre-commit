#!/bin/sh
set -e

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-sensitive-files.ps1 -Staged
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-sensitive-files.ps1 -Staged
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-sensitive-files.ps1 -Staged
else
  echo "PowerShell is required for RepoRadar pre-commit secret checks." >&2
  exit 1
fi
