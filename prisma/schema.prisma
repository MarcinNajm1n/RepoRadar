generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Repository {
  id                String    @id @default(cuid())
  githubId          Int       @unique
  fullName          String    @unique
  owner             String
  name              String
  url               String
  description       String?
  readmeHash        String?
  readmeExcerpt     String?
  primaryLanguage   String?
  topicsJson        String    @default("[]")
  license           String?
  createdAt         DateTime
  pushedAt          DateTime?
  firstSeenAt       DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  starsCurrent      Int       @default(0)
  forksCurrent      Int       @default(0)
  watchersCurrent   Int       @default(0)
  openIssues        Int       @default(0)
  ageMonths         Int       @default(0)
  isOldRepo         Boolean   @default(false)
  isArchived        Boolean   @default(false)
  isFork            Boolean   @default(false)
  isDeletedFromView Boolean   @default(false)
  status            String    @default("NEW")
  shortSummaryPl    String?
  lastAnalyzedAt    DateTime?
  trendScore        Int       @default(0)
  relevanceScore    Int       @default(0)
  initialMomentumScore Int    @default(0)
  scoreBreakdownJson String   @default("{}")
  discoveryProfilesJson String @default("[]")
  source            String    @default("github")
  createdDbAt       DateTime  @default(now())
  updatedDbAt       DateTime  @updatedAt

  snapshots             RepoSnapshot[]
  reports               Report[]
  ideas                 Idea[]
  openaiCache           OpenAiCache[]
  marketResearchRuns    MarketResearchRun[]
  marketResearchSources MarketResearchSource[]
  ignoredRecord         IgnoredRepository?
  actionItems           ActionItem[]

  @@index([status])
  @@index([trendScore])
  @@index([starsCurrent])
  @@index([pushedAt])
  @@index([createdAt])
  @@index([isOldRepo])
  @@index([source])
}

model RepoSnapshot {
  id              String    @id @default(cuid())
  repoId          String
  capturedAt      DateTime  @default(now())
  stars           Int
  forks           Int
  watchers        Int
  openIssues      Int
  pushedAt        DateTime?
  growth24h       Int?
  growth7d        Int?
  growthPercent7d Float?

  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId, capturedAt])
}

model Report {
  id              String   @id @default(cuid())
  type            String
  repoId          String?
  title           String
  markdownPath    String?
  contentMarkdown String
  summary         String?
  repoCount       Int      @default(0)
  topRepoIdsJson  String   @default("[]")
  inputHash       String?
  createdAt       DateTime @default(now())

  repository            Repository?            @relation(fields: [repoId], references: [id], onDelete: SetNull)
  marketResearchRuns    MarketResearchRun[]
  marketResearchSources MarketResearchSource[]
  actionItems           ActionItem[]

  @@index([type])
  @@index([createdAt])
  @@index([repoId])
}

model Idea {
  id                    String   @id @default(cuid())
  sourceRepoId          String
  title                 String
  problem               String
  proposedSolution      String
  targetUser            String
  mvpScope              String
  monetizationPotential String
  difficulty            Int
  usefulnessScore       Int
  riskScore             Int
  suggestedStack        String
  firstStepsJson        String   @default("[]")
  marketSummary         String?
  evidenceIdsJson       String   @default("[]")
  confidenceScore       Int?
  opportunityScore      Int?
  opportunityBreakdownJson String @default("{}")
  applicationSummary    String?
  businessRationale     String?
  researchMode          String   @default("full")
  status                String   @default("NEW")
  lastResearchAt        DateTime?
  createdAt             DateTime @default(now())

  repository            Repository             @relation(fields: [sourceRepoId], references: [id], onDelete: Cascade)
  marketResearchRuns    MarketResearchRun[]
  marketResearchSources MarketResearchSource[]
  actionItems           ActionItem[]

  @@index([sourceRepoId])
  @@index([status])
  @@index([researchMode])
}

model IgnoredRepository {
  id        String   @id @default(cuid())
  repoId    String?  @unique
  fullName  String   @unique
  reason    String?
  ignoredAt DateTime @default(now())
  permanent Boolean  @default(true)

  repository Repository? @relation(fields: [repoId], references: [id], onDelete: SetNull)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ActionItem {
  id            String    @id @default(cuid())
  type          String
  status        String    @default("OPEN")
  title         String
  description   String?
  repoId        String?
  ideaId        String?
  reportId      String?
  priority      Int       @default(0)
  dueAt         DateTime?
  snoozedUntil  DateTime?
  completedAt   DateTime?
  dismissedAt   DateTime?
  dedupeKey     String?   @unique
  metadataJson  String    @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  repository Repository? @relation(fields: [repoId], references: [id], onDelete: SetNull)
  idea       Idea?       @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  report     Report?     @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([snoozedUntil])
  @@index([repoId])
  @@index([ideaId])
  @@index([reportId])
  @@index([createdAt])
}

model ScanRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    @default("RUNNING")
  reposFound   Int       @default(0)
  reposUpdated Int       @default(0)
  errorMessage String?

  @@index([startedAt])
  @@index([status])
}

model OpenAiCache {
  id        String   @id @default(cuid())
  kind      String
  repoId    String?
  inputHash String
  model     String
  content   String
  createdAt DateTime @default(now())

  repository Repository? @relation(fields: [repoId], references: [id], onDelete: SetNull)

  @@unique([kind, repoId, inputHash, model])
  @@index([kind])
  @@index([createdAt])
}

model MarketResearchRun {
  id          String    @id @default(cuid())
  repoId      String?
  reportId    String?
  ideaId      String?
  provider    String
  mode        String    @default("full")
  queryHash   String
  queriesJson String    @default("[]")
  providersJson String  @default("[]")
  status      String    @default("RUNNING")
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  sourceCount Int       @default(0)
  error       String?

  repository Repository?            @relation(fields: [repoId], references: [id], onDelete: SetNull)
  report     Report?                @relation(fields: [reportId], references: [id], onDelete: SetNull)
  idea       Idea?                  @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  sources    MarketResearchSource[]

  @@index([repoId])
  @@index([reportId])
  @@index([ideaId])
  @@index([provider])
  @@index([mode])
  @@index([queryHash])
  @@index([status])
  @@index([startedAt])
}

model MarketResearchSource {
  id             String    @id @default(cuid())
  runId          String
  repoId         String?
  reportId       String?
  ideaId         String?
  sourceType     String
  title          String
  url            String
  publisher      String?
  retrievedAt    DateTime  @default(now())
  publishedAt    DateTime?
  snippet        String
  sentiment      String?
  relevanceScore Int?
  canonicalUrl   String?
  sourceKey      String?
  evidenceKind   String?
  whatItProves   String?
  sourceConfidence Int?
  sourceRank     Int?

  run        MarketResearchRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  repository Repository?       @relation(fields: [repoId], references: [id], onDelete: SetNull)
  report     Report?           @relation(fields: [reportId], references: [id], onDelete: SetNull)
  idea       Idea?             @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([repoId])
  @@index([reportId])
  @@index([ideaId])
  @@index([sourceType])
  @@index([retrievedAt])
  @@index([sourceKey])
  @@index([canonicalUrl])
  @@index([evidenceKind])
  @@index([sourceConfidence])
}

model ExternalResearchCache {
  id          String   @id @default(cuid())
  provider    String
  cacheKey    String
  mode        String?
  query       String?
  contentJson String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, cacheKey])
  @@index([provider])
  @@index([expiresAt])
  @@index([createdAt])
}

model NotificationLog {
  id           String   @id @default(cuid())
  channel      String
  eventType    String
  status       String
  maskedTarget String?
  payloadJson  String?
  error        String?
  createdAt    DateTime @default(now())

  @@index([channel])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}
